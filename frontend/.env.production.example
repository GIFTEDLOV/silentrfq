# Copy this file to .env.local (local) or set these in your Vercel project settings.
# All values are required for the Sepolia deployment.

# Sepolia chain ID — do not change for production.
NEXT_PUBLIC_CHAIN_ID=11155111

# Address of the deployed SilentRFQFactory contract on Sepolia.
NEXT_PUBLIC_FACTORY_ADDRESS=

# WalletConnect Cloud project ID — https://cloud.walletconnect.com
# Required for WalletConnect support. MetaMask injected works without it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
