# Address of the deployed SilentRFQFactory contract.
# Run: npx hardhat run scripts/deployFactory.ts --network localhost
# Copy the printed address here.
NEXT_PUBLIC_FACTORY_ADDRESS=

# Chain ID the frontend targets.
# 31337 = Hardhat local node  |  11155111 = Sepolia
NEXT_PUBLIC_CHAIN_ID=31337

# WalletConnect Project ID from https://cloud.walletconnect.com
# Not required for MetaMask/injected wallets on localhost.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
